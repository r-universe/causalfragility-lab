[submodule ".registry"]
	path = .registry
	url = https://github.com/r-universe-org/cran-to-git
	branch = HEAD
[submodule "AIBias"]
	path = AIBias
	url = https://github.com/causalfragility-lab/aibias
[submodule "CEDMr"]
	path = CEDMr
	url = https://github.com/causalfragility-lab/cedmr
[submodule "CausalSpline"]
	path = CausalSpline
	url = https://github.com/causalfragility-lab/causalspline
[submodule "DecisionDrift"]
	path = DecisionDrift
	url = https://github.com/causalfragility-lab/decisiondrift
[submodule "MLCausal"]
	path = MLCausal
	url = https://github.com/causalfragility-lab/mlcausal
[submodule "MultiSpline"]
	path = MultiSpline
	url = https://github.com/causalfragility-lab/multispline
[submodule "RobustMediate"]
	path = RobustMediate
	url = https://github.com/causalfragility-lab/robustmediate
[submodule "achieveGap"]
	path = achieveGap
	url = https://github.com/causalfragility-lab/achievegap
[submodule "confoundvis"]
	path = confoundvis
	url = https://github.com/causalfragility-lab/confoundvis
[submodule "decisionpaths"]
	path = decisionpaths
	url = https://github.com/causalfragility-lab/decisionpaths
[submodule "drmeta"]
	path = drmeta
	url = https://github.com/causalfragility-lab/drmeta
[submodule "hlmLab"]
	path = hlmLab
	url = https://github.com/causalfragility-lab/hlmlab
[submodule "metaLong"]
	path = metaLong
	url = https://github.com/causalfragility-lab/metalong
[submodule "mlmoderator"]
